# ─────────────────────────────────────────────────────────────────────────────
# Sicurre-ML — Environment Variable Reference
#
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# On Kaggle these are loaded from Kaggle Secrets (not this file).
# On Colab they are loaded from Colab userdata.
# Locally they are loaded by python-dotenv via load_secrets().
# ─────────────────────────────────────────────────────────────────────────────

# ── HuggingFace ──────────────────────────────────────────────────────────────
# Write-access token for pushing trained models to the Hub.
HF_TOKEN=hf_...

# Your HuggingFace account username (used to build the repo ID).
HF_USERNAME=your-huggingface-username

# The model repository name on HuggingFace Hub.
REPO_NAME=sicurre-phishing-fr

# ── Databricks / MLflow ──────────────────────────────────────────────────────
# Leave blank to fall back to local MLflow (file:./mlruns).
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
DATABRICKS_EMAIL=you@example.com

# MLflow experiment name.  On Databricks this becomes /Users/<email>/<name>.
MLFLOW_EXPERIMENT_NAME=sicurre-phishing

# ── Kaggle (CI orchestration only — not needed for local training) ───────────
# Used by the GitHub Actions workflow to upload src/ and trigger notebook runs.
# Set these as GitHub repository secrets, not in .env.
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Slug of the Kaggle dataset that holds the frozen training CSV splits.
# Format: <kaggle-username>/<dataset-name>
KAGGLE_TRAINING_DATASET=your-kaggle-username/sicurre-data

# ── Inference API ─────────────────────────────────────────────────────────────
# Secret token that callers must provide in the Authorization: Bearer header.
INFERENCE_API_KEY=your-secret-inference-api-key
# Comma-separated trusted HTTP Host values. Do not use a wildcard in production.
INFERENCE_ALLOWED_HOSTS=api.sicurre.com,app,localhost,127.0.0.1

# ── LLM tier chain ────────────────────────────────────────────────────────────
# Groq (Tier 1) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Cerebras (Tier 2) — https://cloud.cerebras.ai/platform
CEREBRAS_API_KEY=csk_...

# Gemini (Tier 3) — https://ai.google.dev/
GEMINI_API_KEY=AIza...

# ── PhishTank blocklist ──────────────────────────────────────────────────────
# Canonical source is the Sicurre data platform Neon database. The local file is
# a warmed fallback snapshot rewritten after each successful database refresh.
PHISHTANK_SOURCE=database
SICURRE_DATA_PLATFORM_DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require
PHISHTANK_FILE_PATH=/absolute/path/to/phishtank_urls.json

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Composite score threshold for the phishing verdict (default: 0.5).
PHISHING_THRESHOLD=0.5
WEIGHT_RULES=0.10
WEIGHT_BLOCKLIST=0.25
WEIGHT_ONNX=0.20
WEIGHT_LLM=0.45

# ── ONNX model cache ──────────────────────────────────────────────────────────
# Directory where the ONNX model file is cached after download from HF Hub.
# In Docker the named volume is mounted here; change only if needed.
ONNX_MODEL_CACHE_DIR=/tmp/sicurre_onnx
ONNX_NUM_THREADS=your-number-of-cpu-threads-for-onnx

# Service-to-service rate limiting (single process, conservative CX33 defaults).
INFERENCE_RATE_LIMIT_RPS=1
INFERENCE_RATE_LIMIT_BURST=5

# Bounded external LLM calls and provider circuit breaker.
LLM_CONNECT_TIMEOUT_SECONDS=3
LLM_RESPONSE_TIMEOUT_SECONDS=12
LLM_MAX_ATTEMPTS=2
LLM_RETRY_BACKOFF_SECONDS=0.25
LLM_CIRCUIT_BREAKER_FAILURES=3
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# OpenTelemetry request tracing (sent to the local Alloy receiver)
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACE_SAMPLE_RATIO=1.0
DEPLOYMENT_ENV=production
# Independent release and artifact identity dimensions.
SERVICE_VERSION=0.1.0
MODEL_VERSION=phishing-detector-1.0.0
DATASET_VERSION=unknown
DEPLOYMENT_REVISION=unknown
CONTAINER_IMAGE_DIGEST=unknown
#
# IMAGE_TAG is injected automatically by the CD workflow — you do not set it.
IMAGE_TAG=latest
