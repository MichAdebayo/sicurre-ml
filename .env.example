# ─────────────────────────────────────────────────────────────────────────────
# Sicurre-ML — Environment Variable Reference
#
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# On Kaggle these are loaded from Kaggle Secrets (not this file).
# On Colab they are loaded from Colab userdata.
# Locally they are loaded by python-dotenv via load_secrets().
# ─────────────────────────────────────────────────────────────────────────────

# ── HuggingFace ──────────────────────────────────────────────────────────────
# Write-access token for pushing trained models to the Hub.
HF_TOKEN=hf_...

# Your HuggingFace account username (used to build the repo ID).
HF_USERNAME=your-huggingface-username

# The model repository name on HuggingFace Hub.
REPO_NAME=sicurre-phishing-detector

# ── Databricks / MLflow ──────────────────────────────────────────────────────
# Leave blank to fall back to local MLflow (file:./mlruns).
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
DATABRICKS_EMAIL=you@example.com

# MLflow experiment name.  On Databricks this becomes /Users/<email>/<name>.
MLFLOW_EXPERIMENT_NAME=sicurre-phishing

# ── Kaggle (CI orchestration only — not needed for local training) ───────────
# Used by the GitHub Actions workflow to upload src/ and trigger notebook runs.
# Set these as GitHub repository secrets, not in .env.
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Slug of the Kaggle dataset that holds the frozen training CSV splits.
# Format: <kaggle-username>/<dataset-name>
KAGGLE_TRAINING_DATASET=your-kaggle-username/sicurre-data
