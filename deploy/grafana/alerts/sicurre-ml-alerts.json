[
  {"uid":"sicurre-ml-unavailable","title":"Sicurre ML service unavailable","expr":"min_over_time(up{stack=\"sicurre-ml\",service_name=\"sicurre-ml-inference\"}[5m])","operator":"lt","threshold":1,"for":"5m","severity":"critical","no_data":"Alerting"},
  {"uid":"sicurre-ml-model-not-ready","title":"Sicurre ML model not ready","expr":"min_over_time(sicurre_model_ready{stack=\"sicurre-ml\"}[5m])","operator":"lt","threshold":1,"for":"5m","severity":"critical","no_data":"Alerting"},
  {"uid":"sicurre-ml-local-p95","title":"Sicurre ML local inference p95 above 1s","expr":"histogram_quantile(0.95, sum by (le) (rate(sicurre_inference_mode_request_latency_ms_bucket{stack=\"sicurre-ml\",mode=\"local\"}[10m])))","operator":"gt","threshold":1000,"for":"10m","severity":"warning"},
  {"uid":"sicurre-ml-llm-p95","title":"Sicurre ML LLM inference p95 above 8s","expr":"histogram_quantile(0.95, sum by (le) (rate(sicurre_inference_mode_request_latency_ms_bucket{stack=\"sicurre-ml\",mode=\"llm\"}[10m])))","operator":"gt","threshold":8000,"for":"10m","severity":"warning"},
  {"uid":"sicurre-ml-error-rate","title":"Sicurre ML server error rate above 2%","expr":"sum(rate(sicurre_inference_request_status_total{stack=\"sicurre-ml\",status_code=~\"5..\"}[10m])) / clamp_min(sum(rate(sicurre_inference_requests_total{stack=\"sicurre-ml\"}[10m])), 0.001)","operator":"gt","threshold":0.02,"for":"10m","severity":"critical"},
  {"uid":"sicurre-ml-auth-spike","title":"Sicurre ML authentication rejection spike","expr":"sum(increase(sicurre_auth_failure_total{stack=\"sicurre-ml\"}[10m]))","operator":"gt","threshold":5,"for":"5m","severity":"warning"},
  {"uid":"sicurre-ml-rate-limit-spike","title":"Sicurre ML rate-limit spike","expr":"sum(increase(sicurre_rate_limit_total{stack=\"sicurre-ml\"}[10m]))","operator":"gt","threshold":10,"for":"5m","severity":"warning"},
  {"uid":"sicurre-ml-memory-pressure","title":"Sicurre ML process memory above 6 GiB","expr":"max_over_time(sicurre_process_resident_memory_bytes{stack=\"sicurre-ml\"}[10m])","operator":"gt","threshold":6442450944,"for":"10m","severity":"critical"},
  {"uid":"sicurre-ml-telemetry-scrape","title":"Sicurre ML telemetry scrape unavailable","expr":"min_over_time(up{stack=\"sicurre-ml\",service_name=\"sicurre-ml-alloy\"}[10m])","operator":"lt","threshold":1,"for":"10m","severity":"warning","no_data":"Alerting"},
  {"uid":"sicurre-ml-loki-drop","title":"Sicurre ML Alloy is dropping log entries","expr":"sum(increase(loki_write_dropped_entries_total{stack=\"sicurre-ml\",service_name=\"sicurre-ml-alloy\"}[10m]))","operator":"gt","threshold":0,"for":"5m","severity":"warning"},
  {"uid":"sicurre-ml-series-70","title":"Sicurre ML active series above 70% budget","expr":"count({stack=\"sicurre-ml\"})","operator":"gt","threshold":2100,"for":"15m","severity":"warning"},
  {"uid":"sicurre-ml-series-85","title":"Sicurre ML active series above 85% budget","expr":"count({stack=\"sicurre-ml\"})","operator":"gt","threshold":2550,"for":"15m","severity":"critical"}
]
